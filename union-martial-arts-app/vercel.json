{
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "unionmartialarts.org" }],
      "destination": "/landing.html"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.unionmartialarts.org" }],
      "destination": "/landing.html"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/css/(.*).css",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
